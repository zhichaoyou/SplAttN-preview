# Auto detect text files and perform LF normalization
* text=auto

# Ensure consistent line endings
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.pth binary
*.ckpt binary
*.h5 binary
*.npy binary
*.npz binary
*.png binary
*.jpg binary
*.jpeg binary
